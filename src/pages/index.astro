---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import Badge from '../components/Badge.astro';
import Mascot from '../components/Mascot.astro';
import BrandPrinciples from '../components/BrandPrinciples.astro';
import Card from '../components/Card.astro';
import Input from '../components/Input.astro';
import Toggle from '../components/Toggle.astro';
import Pattern from '../components/Pattern.astro';
---

<Layout>
  <div class="min-h-screen bg-navy-900 text-foreground font-sans" style="background-image:radial-gradient(at 8% 0%, rgba(0,223,255,0.07) 0px, transparent 45%), radial-gradient(at 96% 4%, rgba(251,176,64,0.07) 0px, transparent 42%);">
    <header class="h-[52px] flex items-center justify-between px-4 bg-navy-950 border-b border-navy-800">
      <div class="flex items-center gap-2.5">
        <Mascot variant="full" size={30} />
        <span class="text-base font-bold tracking-tight">CodePom</span>
        <span class="font-mono text-[10px] text-navy-950 bg-amber-400 px-[7px] py-[2px] rounded-[5px] font-bold">DS v1.0</span>
      </div>
      <div class="flex items-center gap-[18px] text-[13px] text-muted">
        <span class="flex items-center gap-[6px]">
          <span class="w-[7px] h-[7px] rounded-full bg-cyan-400 shadow-[0_0_8px_#00DFFF]"></span>
          Dark theme
        </span>
        <span class="font-mono">codepom.com</span>
      </div>
    </header>

    <main class="max-w-[980px] mx-auto px-11 py-10">
      <div class="mb-8">
        <div class="font-mono text-[12px] text-cyan-400 mb-2.5">WELCOME</div>
        <h1 class="text-[34px] font-bold tracking-tight leading-[1.05] mb-2.5">CodePom Design System</h1>
        <p class="text-muted text-base max-w-[620px] leading-relaxed">
          Pioneering agile web engineering &amp; fiercely loyal tech partners. Built with Astro + Storybook + Tailwind CSS.
        </p>
      </div>

      <div class="border border-navy-800 rounded-[14px] bg-card p-8 mb-8">
        <div class="font-mono text-[11px] text-muted mb-5">QUICK START</div>
        <div class="flex flex-wrap gap-3 items-center">
          <Button variant="primary" size="md">npm run storybook</Button>
          <Button variant="secondary" size="md">npm run dev</Button>
          <Button variant="accent" size="md">npm run build</Button>
          <Button variant="outline" size="md">Read the docs</Button>
          <Button variant="ghost" size="md">Give feedback</Button>
          <Badge variant="primary">Storybook</Badge>
          <Badge variant="accent">Astro 6</Badge>
          <Badge variant="secondary" dot>Live</Badge>
          <Badge variant="warning">v0.1.0</Badge>
        </div>
      </div>

      <div class="mb-8">
        <h2 class="font-mono text-[14px] text-muted tracking-widest mb-3.5">BRAND PRINCIPLES</h2>
        <BrandPrinciples />
      </div>

      <div class="mb-8">
        <h2 class="font-mono text-[14px] text-muted tracking-widest mb-3.5">FOUNDATIONS</h2>
        <div class="grid grid-cols-3 gap-4">
          <Card>
            <div class="p-6 flex flex-col items-center gap-4">
              <Mascot variant="full" size={80} />
              <div class="text-center">
                <div class="font-semibold text-sm">Logo &amp; Mascot</div>
                <div class="text-[12px] text-muted mt-0.5">3 variants</div>
              </div>
            </div>
          </Card>
          <Card>
            <div class="p-6 flex flex-col gap-4">
              <div class="flex gap-2">
                <span class="w-8 h-8 rounded-[6px] bg-navy-950 border border-navy-800"></span>
                <span class="w-8 h-8 rounded-[6px] bg-amber-400"></span>
                <span class="w-8 h-8 rounded-[6px] bg-cyan-400"></span>
                <span class="w-8 h-8 rounded-[6px] bg-ivory-50"></span>
              </div>
              <div class="text-center">
                <div class="font-semibold text-sm">Colors &amp; Tokens</div>
                <div class="text-[12px] text-muted mt-0.5">Navy · Amber · Cyan · Ivory</div>
              </div>
            </div>
          </Card>
          <Card>
            <div class="p-6 flex flex-col items-center gap-4">
              <div class="flex gap-6 text-center">
                <div><div class="text-3xl font-bold tracking-tighter">Aa</div><div class="text-[10px] text-muted">Sans</div></div>
                <div><div class="text-3xl font-bold font-mono">Aa</div><div class="text-[10px] text-muted">Mono</div></div>
              </div>
              <div class="text-center">
                <div class="font-semibold text-sm">Typography</div>
                <div class="text-[12px] text-muted mt-0.5">Space Grotesk + Space Mono</div>
              </div>
            </div>
          </Card>
        </div>
      </div>

      <div class="mb-8">
        <h2 class="font-mono text-[14px] text-muted tracking-widest mb-3.5">BACKGROUND PATTERN</h2>
        <Pattern />
      </div>

      <div class="mb-8">
        <h2 class="font-mono text-[14px] text-muted tracking-widest mb-3.5">SAMPLE FORM</h2>
        <div class="border border-navy-800 rounded-[12px] bg-card p-6">
          <div class="grid grid-cols-2 gap-4 mb-4">
            <Input label="Project name" value="codepom-web" hint="Lowercase, hyphenated." />
            <div>
              <label class="text-[13px] font-semibold block mb-[7px]">Stack</label>
              <select class="w-full appearance-none font-sans text-[14px] bg-navy-900 border border-navy-800 rounded-[8px] px-[12px] py-[10px] text-foreground outline-none cursor-pointer">
                <option>Next.js + Tailwind</option>
                <option selected>Astro</option>
                <option>Remix</option>
              </select>
            </div>
          </div>
          <div class="flex items-center justify-between mb-4">
            <div>
              <div class="text-[13px] font-semibold">Notifications</div>
              <div class="text-[12px] text-muted">Push alerts</div>
            </div>
            <Toggle checked />
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>
