---
export type AvatarSize = 'xs' | 'sm' | 'md' | 'lg' | 'xl';
export type AvatarStatus = 'online' | 'away' | 'busy' | 'offline' | 'none';

interface Props {
  src?: string;
  initials?: string;
  name?: string;
  size?: AvatarSize;
  status?: AvatarStatus;
  class?: string;
}

const { src, initials, name, size = 'md', status = 'none' } = Astro.props;

const sizes: Record<AvatarSize, { wrap: string; text: string; ring: string; status: string }> = {
  xs: { wrap: 'w-6 h-6',   text: 'text-[10px]', ring: 'ring-[1.5px]', status: 'w-1.5 h-1.5 border' },
  sm: { wrap: 'w-8 h-8',   text: 'text-[11px]', ring: 'ring-2',       status: 'w-2 h-2 border' },
  md: { wrap: 'w-10 h-10', text: 'text-[13px]', ring: 'ring-2',       status: 'w-2.5 h-2.5 border-2' },
  lg: { wrap: 'w-12 h-12', text: 'text-[15px]', ring: 'ring-[3px]',   status: 'w-3 h-3 border-2' },
  xl: { wrap: 'w-16 h-16', text: 'text-[19px]', ring: 'ring-[3px]',   status: 'w-3.5 h-3.5 border-2' },
};

const statusColors: Record<AvatarStatus, string> = {
  online:  'bg-success',
  away:    'bg-amber-400',
  busy:    'bg-error',
  offline: 'bg-navy-700',
  none:    'hidden',
};

const s = sizes[size];

// Deterministic color from initials/name so same person always gets same color
const seed = (initials ?? name ?? 'U').charCodeAt(0) % 5;
const bgColors = [
  'bg-gradient-to-br from-amber-400 to-amber-600',
  'bg-gradient-to-br from-cyan-400 to-cyan-500',
  'bg-gradient-to-br from-success to-[#16a34a]',
  'bg-gradient-to-br from-[#a78bfa] to-[#7c3aed]',
  'bg-gradient-to-br from-error to-[#dc2626]',
];
const textColors = ['text-navy-950', 'text-navy-950', 'text-navy-950', 'text-white', 'text-white'];
---

<div
  class={`relative inline-flex flex-none ${s.wrap} ${Astro.props.class ?? ''}`}
  title={name}
>
  {src ? (
    <img
      src={src}
      alt={name ?? 'Avatar'}
      class={`${s.wrap} rounded-full object-cover ring-navy-800 ${s.ring}`}
    />
  ) : (
    <div
      class={`${s.wrap} rounded-full flex items-center justify-center font-semibold font-sans select-none ${bgColors[seed]} ${textColors[seed]}`}
      aria-hidden="true"
    >
      <span class={s.text}>{(initials ?? name?.slice(0, 2) ?? 'U').toUpperCase()}</span>
    </div>
  )}
  {status !== 'none' && (
    <span
      class={`absolute bottom-0 right-0 rounded-full border-navy-900 ${s.status} ${statusColors[status]}`}
      aria-label={`Status: ${status}`}
    />
  )}
  {name && <span class="sr-only">{name}</span>}
</div>
