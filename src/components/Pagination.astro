---
interface Props {
  total: number;
  page: number;
  perPage?: number;
  class?: string;
}

const { total, page, perPage = 10 } = Astro.props;
const totalPages = Math.ceil(total / perPage);
const hasPrev = page > 1;
const hasNext = page < totalPages;

// Build page range with ellipsis
function getPages(current: number, total: number): (number | '...')[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  if (current <= 4) return [1, 2, 3, 4, 5, '...', total];
  if (current >= total - 3) return [1, '...', total-4, total-3, total-2, total-1, total];
  return [1, '...', current-1, current, current+1, '...', total];
}

const pages = getPages(page, totalPages);
const btnBase = 'inline-flex items-center justify-center w-9 h-9 rounded-lg text-sm font-medium transition-colors duration-100 cursor-pointer border';
const activeCls = `${btnBase} bg-amber-400 text-navy-950 border-amber-400 font-semibold`;
const inactiveCls = `${btnBase} bg-transparent text-muted border-navy-800 hover:border-navy-700 hover:text-foreground`;
const disabledCls = `${btnBase} bg-transparent text-navy-700 border-navy-800 opacity-40 cursor-not-allowed`;
---

<nav aria-label="Pagination" class={`flex items-center gap-1 ${Astro.props.class ?? ''}`}>
  <button
    class={hasPrev ? inactiveCls : disabledCls}
    aria-label="Previous page"
    aria-disabled={!hasPrev}
    disabled={!hasPrev}
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
  </button>

  {pages.map(p =>
    p === '...' ? (
      <span class="w-9 h-9 flex items-center justify-center text-muted text-sm select-none">…</span>
    ) : (
      <button
        class={p === page ? activeCls : inactiveCls}
        aria-label={`Page ${p}`}
        aria-current={p === page ? 'page' : undefined}
      >
        {p}
      </button>
    )
  )}

  <button
    class={hasNext ? inactiveCls : disabledCls}
    aria-label="Next page"
    aria-disabled={!hasNext}
    disabled={!hasNext}
  >
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
  </button>
</nav>
