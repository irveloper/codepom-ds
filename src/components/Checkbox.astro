---
interface Props {
  label?: string;
  checked?: boolean;
  class?: string;
  id?: string;
}

const { label, checked = false, id } = Astro.props;
const inputId = id || `checkbox-${Math.random().toString(36).slice(2, 9)}`;
---

<label for={inputId} class="inline-flex items-center gap-[10px] text-[14px] text-[#E2E8F0] cursor-pointer" class:list={[Astro.props.class]}>
  <span class="w-[19px] h-[19px] flex-none flex items-center justify-center transition-all duration-100" class:list={[checked ? 'bg-amber-400 rounded-[5px]' : 'border border-navy-700 rounded-[5px]']}>
    {checked && (
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#08192E" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"></path></svg>
    )}
  </span>
  {label}
</label>
