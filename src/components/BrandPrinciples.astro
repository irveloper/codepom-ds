---
import Mascot from './Mascot.astro';

interface Props {
  class?: string;
}
---

<div class="grid grid-cols-3 gap-[16px]" class:list={[Astro.props.class]}>
  <div class="border border-navy-800 rounded-[14px] bg-card p-[28px]">
    <div class="text-amber-400 mb-[18px]">
      <svg width="38" height="38" viewBox="0 0 48 48" fill="none" aria-hidden="true">
        <polyline points="15,14 9,24 15,34" stroke="#00DFFF" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
        <polyline points="33,14 39,24 33,34" stroke="#00DFFF" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
        <polygon points="26,12 19,26 24,26 22,36 30,21 25,21" fill="currentColor" />
      </svg>
    </div>
    <div class="text-[20px] font-bold mb-[8px]">Agility</div>
    <p class="m-0 text-[14px] text-muted leading-[1.55]">Ship fast and iterate. Lightweight process, sharp execution, quick to adapt.</p>
  </div>
  <div class="border border-navy-800 rounded-[14px] bg-card p-[28px]">
    <div class="text-amber-400 mb-[18px]">
      <svg width="38" height="38" viewBox="0 0 48 48" fill="none" aria-hidden="true">
        <path d="M4 20 L16 27 L23 23" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M44 20 L32 27 L25 23" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
        <rect x="20" y="21" width="8" height="11" rx="2" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M16 27 l4 -3" stroke="#00DFFF" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </div>
    <div class="text-[20px] font-bold mb-[8px]">Partnership</div>
    <p class="m-0 text-[14px] text-muted leading-[1.55]">Fiercely loyal. We work as an extension of your team, not a vendor at arm's length.</p>
  </div>
  <div class="border border-navy-800 rounded-[14px] bg-card p-[28px]">
    <div class="text-amber-400 mb-[18px]">
      <svg width="38" height="38" viewBox="0 0 48 48" fill="none" aria-hidden="true">
        <path d="M10 14 v-4 h4" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M38 14 v-4 h-4" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M10 34 v-4 h4" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M38 34 v-4 h-4" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
        <g fill="currentColor">
          <ellipse cx="24" cy="28" rx="6.6" ry="4.95" />
          <circle cx="17.4" cy="20.7" r="2.64" />
          <circle cx="21.8" cy="17.4" r="2.64" />
          <circle cx="26.2" cy="17.4" r="2.64" />
          <circle cx="30.6" cy="20.7" r="2.64" />
        </g>
      </svg>
    </div>
    <div class="text-[20px] font-bold mb-[8px]">Integrity</div>
    <p class="m-0 text-[14px] text-muted leading-[1.55]">Honest estimates, clean code, no shortcuts. We do what we say we'll do.</p>
  </div>
</div>

<div class="mt-[16px] border border-navy-800 rounded-[14px] bg-[linear-gradient(120deg,#08192E,#0f2747)] p-[30px] flex items-center gap-[24px]">
  <div class="w-[80px] h-[80px] flex-none">
    <Mascot size={80} variant="full" />
  </div>
  <div>
    <div class="text-[22px] font-bold tracking-tight">Pioneering agile web engineering<br/>& fiercely loyal tech partners.</div>
  </div>
</div>
