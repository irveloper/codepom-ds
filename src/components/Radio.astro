---
interface Props {
  label?: string;
  checked?: boolean;
  name?: string;
  class?: string;
  id?: string;
}

const { label, checked = false, name = 'radio', id } = Astro.props;
const inputId = id || `radio-${Math.random().toString(36).slice(2, 9)}`;
---

<label for={inputId} class="inline-flex items-center gap-[10px] text-[14px] cursor-pointer" class:list={[checked ? 'text-[#E2E8F0]' : 'text-muted', Astro.props.class]}>
  <span class="w-[19px] h-[19px] flex-none rounded-full flex items-center justify-center transition-all duration-100" class:list={[checked ? 'border border-cyan-400' : 'border border-navy-700']}>
    {checked && <span class="w-[9px] h-[9px] rounded-full bg-cyan-400" />}
  </span>
  {label}
</label>
