---
export type TabsVariant = 'underline' | 'pill' | 'boxed';

interface Tab {
  id: string;
  label: string;
  badge?: string | number;
  icon?: string;
  disabled?: boolean;
}

interface Props {
  tabs: Tab[];
  active?: string;
  variant?: TabsVariant;
  class?: string;
}

const { tabs, active, variant = 'underline' } = Astro.props;
const activeId = active ?? tabs[0]?.id;
const uid = `tabs-${Math.random().toString(36).slice(2, 7)}`;

const wrapStyles: Record<TabsVariant, string> = {
  underline: 'border-b border-navy-800 gap-0',
  pill:      'gap-2 p-1 bg-navy-950 rounded-xl',
  boxed:     'gap-0 bg-navy-950 border border-navy-800 rounded-xl p-1',
};

const tabBase: Record<TabsVariant, string> = {
  underline: 'px-4 py-2.5 text-sm font-medium border-b-2 -mb-px transition-colors duration-150 cursor-pointer whitespace-nowrap',
  pill:      'px-4 py-2 text-sm font-medium rounded-lg transition-all duration-150 cursor-pointer whitespace-nowrap',
  boxed:     'px-4 py-2 text-sm font-medium rounded-lg transition-all duration-150 cursor-pointer whitespace-nowrap flex-1 text-center',
};

const activeStyle: Record<TabsVariant, string> = {
  underline: 'border-amber-400 text-amber-400',
  pill:      'bg-navy-800 text-foreground shadow-sm',
  boxed:     'bg-navy-800 text-foreground shadow-sm',
};

const inactiveStyle: Record<TabsVariant, string> = {
  underline: 'border-transparent text-muted hover:text-foreground hover:border-navy-700',
  pill:      'text-muted hover:text-foreground',
  boxed:     'text-muted hover:text-foreground',
};
---

<div class={Astro.props.class}>
  <div
    role="tablist"
    class={`flex items-center ${wrapStyles[variant]}`}
  >
    {tabs.map(tab => (
      <button
        role="tab"
        id={`${uid}-tab-${tab.id}`}
        aria-controls={`${uid}-panel-${tab.id}`}
        aria-selected={tab.id === activeId ? 'true' : 'false'}
        aria-disabled={tab.disabled ? 'true' : undefined}
        data-tab-target={tab.id}
        data-tabs-uid={uid}
        class={`${tabBase[variant]} ${tab.id === activeId ? activeStyle[variant] : inactiveStyle[variant]} ${tab.disabled ? 'opacity-40 pointer-events-none' : ''} inline-flex items-center gap-2`}
      >
        {tab.icon && <span aria-hidden="true" set:html={tab.icon} />}
        {tab.label}
        {tab.badge !== undefined && (
          <span class={`text-[11px] font-semibold px-1.5 py-0.5 rounded-full leading-none ${tab.id === activeId ? 'bg-amber-400/20 text-amber-400' : 'bg-navy-800 text-muted'}`}>
            {tab.badge}
          </span>
        )}
      </button>
    ))}
  </div>

  <div class="mt-4">
    {tabs.map(tab => (
      <div
        role="tabpanel"
        id={`${uid}-panel-${tab.id}`}
        aria-labelledby={`${uid}-tab-${tab.id}`}
        data-tab-panel={tab.id}
        data-tabs-uid={uid}
        hidden={tab.id !== activeId}
      >
        <slot name={tab.id} />
      </div>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll('[data-tab-target]').forEach(btn => {
    btn.addEventListener('click', () => {
      const uid = btn.getAttribute('data-tabs-uid');
      const target = btn.getAttribute('data-tab-target');

      // Update tabs
      document.querySelectorAll(`[data-tabs-uid="${uid}"][data-tab-target]`).forEach(t => {
        const isActive = t.getAttribute('data-tab-target') === target;
        t.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      // Update panels
      document.querySelectorAll(`[data-tabs-uid="${uid}"][data-tab-panel]`).forEach(p => {
        const show = p.getAttribute('data-tab-panel') === target;
        (p as HTMLElement).hidden = !show;
      });
    });

    // Keyboard navigation
    btn.addEventListener('keydown', (e: Event) => {
      const ke = e as KeyboardEvent;
      if (!['ArrowLeft','ArrowRight','Home','End'].includes(ke.key)) return;
      ke.preventDefault();
      const uid = btn.getAttribute('data-tabs-uid');
      const allTabs = Array.from(document.querySelectorAll(`[data-tabs-uid="${uid}"][data-tab-target]:not([aria-disabled="true"])`)) as HTMLElement[];
      const idx = allTabs.indexOf(btn as HTMLElement);
      let next = idx;
      if (ke.key === 'ArrowRight') next = (idx + 1) % allTabs.length;
      if (ke.key === 'ArrowLeft')  next = (idx - 1 + allTabs.length) % allTabs.length;
      if (ke.key === 'Home') next = 0;
      if (ke.key === 'End')  next = allTabs.length - 1;
      allTabs[next].focus();
      allTabs[next].click();
    });
  });
</script>
