---
export type ToastVariant = 'info' | 'success' | 'warning' | 'error';
export type ToastPosition = 'top-right' | 'top-center' | 'bottom-right' | 'bottom-center';

interface Props {
  variant?: ToastVariant;
  title?: string;
  duration?: number;
  position?: ToastPosition;
  class?: string;
}

const { variant = 'info', title, duration = 4000, position = 'bottom-right' } = Astro.props;

const config: Record<ToastVariant, { border: string; iconColor: string; titleColor: string }> = {
  info:    { border: 'border-cyan-400/40',  iconColor: '#00DFFF', titleColor: '#00DFFF' },
  success: { border: 'border-success/40',   iconColor: '#4ADE80', titleColor: '#4ADE80' },
  warning: { border: 'border-warning/40',   iconColor: '#FB923C', titleColor: '#FB923C' },
  error:   { border: 'border-error/40',     iconColor: '#F87171', titleColor: '#F87171' },
};

const positionStyles: Record<ToastPosition, string> = {
  'top-right':     'top-5 right-5',
  'top-center':    'top-5 left-1/2 -translate-x-1/2',
  'bottom-right':  'bottom-5 right-5',
  'bottom-center': 'bottom-5 left-1/2 -translate-x-1/2',
};

const { border, iconColor, titleColor } = config[variant];
const id = `toast-${Math.random().toString(36).slice(2, 7)}`;
---

<div
  id={id}
  role="status"
  aria-live="polite"
  data-toast
  data-duration={duration}
  class={`fixed ${positionStyles[position]} z-50 flex items-start gap-3 bg-navy-900 border ${border} rounded-xl px-4 py-3.5 shadow-[0_8px_32px_0_rgba(5,10,24,0.7),0_4px_8px_0_rgba(5,10,24,0.4)] min-w-[280px] max-w-sm transition-all duration-200 ${Astro.props.class ?? ''}`}
>
  <!-- icon -->
  {variant === 'info' && (
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={iconColor} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex:none;margin-top:1px;" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/>
    </svg>
  )}
  {variant === 'success' && (
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={iconColor} stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex:none;margin-top:1px;" aria-hidden="true">
      <path d="M20 6L9 17l-5-5"/>
    </svg>
  )}
  {variant === 'warning' && (
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={iconColor} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex:none;margin-top:1px;" aria-hidden="true">
      <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
    </svg>
  )}
  {variant === 'error' && (
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke={iconColor} stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex:none;margin-top:1px;" aria-hidden="true">
      <circle cx="12" cy="12" r="10"/><path d="M15 9l-6 6M9 9l6 6"/>
    </svg>
  )}

  <div class="flex-1 min-w-0">
    {title && (
      <p class="font-semibold text-sm mb-0.5 mt-0" style={`color:${titleColor}`}>{title}</p>
    )}
    <div class="text-sm text-muted leading-relaxed">
      <slot />
    </div>
  </div>

  <button
    class="flex-none text-muted hover:text-foreground transition-colors duration-100 cursor-pointer"
    style="margin-top:1px;"
    onclick={`document.getElementById('${id}').remove()`}
    aria-label="Dismiss"
  >
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
      <path d="M18 6L6 18M6 6l12 12"/>
    </svg>
  </button>
</div>

{duration > 0 && (
  <script define:vars={{ id, duration }}>
    setTimeout(() => document.getElementById(id)?.remove(), duration);
  </script>
)}
