---
import Mascot from './Mascot.astro';

interface Props {
  class?: string;
}
---

<div class="flex gap-[24px] flex-wrap" class:list={[Astro.props.class]}>
  <div class="w-[420px] h-[248px] rounded-[14px] bg-[#08192E] border border-navy-800 p-[26px] flex flex-col justify-between relative overflow-hidden shadow-[0_18px_50px_rgba(0,0,0,0.4)]">
    <div class="absolute -right-[30px] -top-[30px] w-[150px] h-[150px] opacity-[0.12]">
      <Mascot size={150} variant="solid" />
    </div>
    <div class="flex items-center gap-[12px] z-[1]">
      <Mascot size={46} variant="full" />
      <div><div class="font-bold text-[20px] tracking-tight">CODEPOM</div><div class="font-mono text-[9px] text-cyan-400 tracking-wider">AGILE WEB ENGINEERING</div></div>
    </div>
    <div class="z-[1]">
      <div class="font-semibold text-[17px]">Maya Chen</div>
      <div class="text-[13px] text-muted mb-[12px]">Lead Engineer</div>
      <div class="flex flex-col gap-[4px] font-mono text-[11px] text-muted">
        <span class="text-amber-400">maya@codepom.com</span>
        <span>+1 422 3456 3859</span>
        <span>codepom.com</span>
      </div>
    </div>
  </div>
  <div class="w-[420px] h-[248px] rounded-[14px] bg-ivory-50 border border-[#e9e6d6] flex flex-col items-center justify-center gap-[14px] shadow-[0_18px_50px_rgba(0,0,0,0.4)]">
    <Mascot size={72} variant="full" />
    <div class="font-bold text-[26px] tracking-tight text-navy-950">CODEPOM</div>
    <div class="font-mono text-[10px] text-[#3A506B] tracking-wider text-center">PIONEERING AGILE WEB ENGINEERING<br/>&amp; FIERCELY LOYAL TECH PARTNERS</div>
  </div>
</div>
