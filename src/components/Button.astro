---
export type ButtonVariant = 'primary' | 'secondary' | 'accent' | 'outline' | 'ghost' | 'destructive';
export type ButtonSize = 'sm' | 'md' | 'lg';

interface Props {
  variant?: ButtonVariant;
  size?: ButtonSize;
  disabled?: boolean;
  class?: string;
}

const { variant = 'primary', size = 'md', disabled = false } = Astro.props;

const variantStyles: Record<ButtonVariant, string> = {
  primary: 'bg-amber-400 text-navy-950 hover:bg-amber-500 border-none',
  secondary: 'bg-navy-800 text-foreground border border-navy-700 hover:bg-[#243150]',
  accent: 'bg-cyan-400 text-navy-950 hover:bg-cyan-500 border-none',
  outline: 'bg-transparent text-amber-400 border border-amber-400 hover:bg-amber-400/12',
  ghost: 'bg-transparent text-foreground hover:bg-navy-800 border-none',
  destructive: 'bg-amber-600 text-ivory-50 hover:bg-[#c2410c] border-none',
};

const sizeStyles: Record<ButtonSize, string> = {
  sm: 'text-[13px] px-[13px] py-[7px] rounded-[7px]',
  md: 'text-[14px] px-[18px] py-[10px] rounded-[8px]',
  lg: 'text-[16px] px-[24px] py-[13px] rounded-[10px]',
};
---

<button
  class={variantStyles[variant] + ' ' + sizeStyles[size] + ' font-sans font-semibold cursor-pointer inline-flex items-center justify-center gap-[8px] leading-none transition-all duration-100'}
  disabled={disabled}
  disabled:class="opacity-45 cursor-not-allowed"
>
  <slot />
</button>
