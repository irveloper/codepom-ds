---
export type CardVariant = 'feature' | 'stat' | 'profile';

interface Props {
  variant?: CardVariant;
  class?: string;
}

const { variant = 'feature' } = Astro.props;

const baseStyles = 'border border-navy-800 rounded-[14px] bg-card overflow-hidden';
---

<div class={baseStyles} class:list={[Astro.props.class]} data-variant={variant}>
  <slot />
</div>
