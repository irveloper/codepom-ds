---
export type MascotVariant = 'full' | 'solid' | 'line';
export type MascotTheme = 'light' | 'dark';

interface Props {
  variant?: MascotVariant;
  theme?: MascotTheme;
  size?: number;
  class?: string;
}

const { variant = 'full', theme = 'light', size = 200 } = Astro.props;

const src = '/logo.svg';
---

<img
  src={src}
  width={size}
  height={size}
  alt="CodePom mascot"
  class={Astro.props.class}
  style="object-fit: contain;"
/>
