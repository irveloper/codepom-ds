---
interface Props {
  label?: string;
  options?: string[];
  value?: string;
  class?: string;
  id?: string;
}

const { label, options = ['Option 1', 'Option 2', 'Option 3'], id } = Astro.props;
const inputId = id || `select-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="flex flex-col gap-[7px]">
  {label && <label for={inputId} class="text-[13px] font-semibold">{label}</label>}
  <div class="relative">
    <select
      id={inputId}
      class="w-full appearance-none font-sans text-[14px] bg-navy-900 border border-navy-800 rounded-[8px] px-[12px] py-[10px] text-foreground outline-none cursor-pointer transition-all duration-100 focus:border-cyan-400 focus:shadow-[0_0_0_3px_rgba(0,223,255,0.15)]"
      class:list={[Astro.props.class]}
    >
      {options.map(opt => <option value={opt}>{opt}</option>)}
    </select>
    <svg class="absolute right-[12px] top-[13px] pointer-events-none" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#64748B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"></path></svg>
  </div>
</div>
