---
interface Props {
  class?: string;
}
---

<div class="border border-navy-800 rounded-[14px] overflow-hidden" class:list={[Astro.props.class]}>
  <div class="h-[280px] bg-navy-900 flex flex-wrap content-start overflow-hidden p-[14px]">
    {
      new Array(80).fill(null).map((_, i) => {
        const seq = ['</>', '🐾', '<>', '{}', '</>', '<>', '$_', '🐾'];
        const g = seq[i % seq.length];
        return <span class="w-[64px] h-[54px] flex items-center justify-center font-mono text-[15px] text-ivory-50/7">{g}</span>;
      })
    }
  </div>
</div>

<div class="grid grid-cols-2 gap-[16px] mt-[20px]">
  <div class="border border-navy-800 rounded-[12px] bg-ivory-50 text-navy-950 p-[22px] flex flex-wrap gap-0 h-[160px] overflow-hidden">
    {
      new Array(24).fill(null).map((_, i) => {
        const seq = ['</>', '🐾', '<>', '{}', '</>', '<>', '$_', '🐾'];
        const g = seq[i % seq.length];
        return <span class="w-[54px] h-[44px] flex items-center justify-center font-mono text-[13px] text-navy-950/10">{g}</span>;
      })
    }
  </div>
  <div class="border border-navy-800 rounded-[12px] bg-card p-[22px] flex flex-col justify-center gap-[10px]">
    <div class="font-semibold text-[15px]">Tileable texture</div>
    <p class="m-0 text-[13px] text-muted leading-[1.55]">Alternating paw glyphs and code brackets at 7–10% opacity. Use behind hero sections and empty states — never under body text.</p>
    <div class="font-mono text-[12px] text-cyan-400 mt-[4px]">opacity: 0.08 · tile 64×54</div>
  </div>
</div>
