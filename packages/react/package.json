{
  "name": "@codepom/react",
  "version": "0.1.0",
  "description": "CodePom design system — React components",
  "type": "module",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/styles.css"
  },
  "main":  "./dist/index.cjs",
  "module":"./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup && cp src/styles.css dist/styles.css",
    "dev":   "tsup --watch"
  },
  "peerDependencies": {
    "react":     ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react":     "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react":            "^18.3.0",
    "react-dom":        "^18.3.0",
    "tsup":             "^8.0.0",
    "typescript":       "^5.4.0"
  },
  "keywords": ["react", "design-system", "codepom", "components"],
  "license": "MIT"
}
